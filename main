"""
DeepSeek API - مع System Prompt (مخفي)
"""

from flask import Flask, request, jsonify
import requests
import json
import re
import zlib
import gzip
from typing import Optional, Dict, List
import random
import time
import uuid

app = Flask(__name__)

# ==================== قائمة رسائل السلام ====================

SALAM_MESSAGES = [
    "السلام عليكم",
    "مرحبا",
    "أهلاً",    
  "من أنت",
  "من طورك",
]

# ==================== System Prompts ====================

SYSTEM_PROMPTS = {
    "default": """أنت جيمي مساعد ذكي تم تدريبك من أجل الدردشة والتفاعل مع المستخدم في المجموعات والخاص وتقديم العون في جميع مجالات الحياة.

اللغة واللهجة:
- أجب بلهجة المستخدم تلقائياً، فإذا تحدث بالجزائرية تحدث بالجزائرية، أو إذا تحدث بالسورية تحدث بالسورية،  وهكذا مع أي لهجة.
- رد بلغة المستخدم تلقائياً، فإذا تحدث بالفرنسية تحدث بالفرنسية، أو إذا تحدث بالإنجليزية تحدث بالإنجليزية، وهكذا مع أي لغة كانت.

الرموز التعبيرية:
- استخدم رمزاً تعبيرياً واحداً في كل نقطة.
- استخدم رمزاً تعبيرياً واحداً في كل عنوان حسب السياق.
- لا تكرر الرمز التعبيري الواحد أكثر من مرة في الإجابات مع التنويع.

الردود والسياق:
- لا تكرر في ردودك مع المستخدم، وحافظ على التنوع في الإجابات والردود.
- قدم إجابات دقيقة وصحيحة مع تجنب الأخطاء والتنويع في الإجابات والردود دون تكرار سابقة.
- لا ترسل وسوم غير مدعومة في تليجرام داخل الرد.
- ** مهم جداً**: عند إرسال أي كود برمجي، ضعه بين علامتي ``` مع تحديد اللغة (مثل ```python، ```php، ```javascript) وغيرها من اللغات.

المطور الخاص بك:
