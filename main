    "arabic": """أنت مساعد ذكاء اصطناعي متخصص في اللغة العربية. اسمك جيمي. تحدث دائماً باللغة العربية الفصحى. ساعد المستخدمين في جميع استفساراتهم بأسلوب مهذب ومفيد.""",
    
    "polite": """أنت مساعد ذكاء اصطناعي مهذب ومحترم. اسمك جيمي. دائماً تبدأ الرد بالسلام وتحترم المستخدم. قدم المساعدة بأسلوب لطيف ومشجع.""",
    
    "professional": """أنت مساعد ذكاء اصطناعي محترف. اسمك جيمي. قدم إجابات دقيقة ومفصلة. استخدم لغة رسمية ومهنية في ردودك."""
}

# ==================== عميل DeepSeek ====================

class DeepSeekClient:
    def __init__(self):
        self.base_url = "https://deepseek-espanol.chat"
        self.ajax_url = f"{self.base_url}/wp-admin/admin-ajax.php"
        self.session = requests.Session()
        self.nonce = None
        self.conversation_id = None
        self.last_index = -1
        self.system_prompt = SYSTEM_PROMPTS["default"]
        
        self.session.get(self.base_url)
        self.refresh_nonce()
    
    def decompress_response(self, content: bytes, encoding: str) -> str:
        try:
            if encoding == 'br':
                try:
                    return zlib.decompress(content, 15 + 32).decode('utf-8')
                except:
                    try:
                        return gzip.decompress(content).decode('utf-8')
                    except:
                        return content.decode('utf-8', errors='ignore')
            elif encoding == 'gzip':
                return gzip.decompress(content).decode('utf-8')
            elif encoding == 'deflate':
                try:
                    return zlib.decompress(content, -15).decode('utf-8')
                except:
                    return zlib.decompress(content).decode('utf-8')
            else:
                return content.decode('utf-8', errors='ignore')
        except:
            return content.decode('utf-8', errors='ignore')
    
    def refresh_nonce(self) -> bool:
        try:
            headers = {
                "User-Agent": "Mozilla/5.0 (Linux; Android 10; K) AppleWebKit/537.36",
                "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9",
                "Accept-Language": "ar-DZ,ar;q=0.9,en-US;q=0.8,en;q=0.7",
            }
            
            r = self.session.get(
                f"{self.base_url}/chat/",
                headers=headers,
                timeout=15
            )
            
            if r.status_code == 200:
                match = re.search(
                    r'nonce["\']?\s*[:=]\s*["\']([a-f0-9]{10})["\']',
                    r.text,
                    re.IGNORECASE
                )
                
                if match:
                    self.nonce = match.group(1)
                    return True
                    
        except Exception as e:
            pass
        
        return False
    
    def format_message_with_system(self, message: str, system_prompt: Optional[str] = None) -> str:
        """دمج system prompt مع رسالة المستخدم"""
        if system_prompt is None:
            system_prompt = self.system_prompt
        
        formatted_message = f"""<|im_start|>system
{system_prompt}<|im_end|>
<|im_start|>user
{message}<|im_end|>
<|im_start|>assistant
"""
        return formatted_message
    
    def send_message(self, message: str, model: str = "deepseek-v4", system_prompt: Optional[str] = None) -> Optional[Dict]:
        if not self.refresh_nonce():
            return None
        
        formatted_message = self.format_message_with_system(message, system_prompt)
        
        boundary = "----WebKitFormBoundary" + "".join([chr(65 + (i % 26)) for i in range(16)])
        
        fields = {
            'action': 'deepseek_chat',
            'message': formatted_message,
            'model': model,
            'nonce': self.nonce,
            'save_conversation': '0',
            'session_only': '1'
        }
        
        if self.conversation_id:
            fields['conversation_id'] = self.conversation_id
        
        body = []
        for key, value in fields.items():
            body.append(f"--{boundary}".encode())
            body.append(f'Content-Disposition: form-data; name="{key}"'.encode())
            body.append(b"")
            body.append(str(value).encode('utf-8'))
        
        body.append(f"--{boundary}--".encode())
        data = b"\r\n".join(body)
        
        headers = {
            "User-Agent": "Mozilla/5.0 (Linux; Android 10; K) AppleWebKit/537.36",
            "Accept": "*/*",
            "Accept-Language": "ar-DZ,ar;q=0.9,en-US;q=0.8,en;q=0.7",
            "Content-Type": f"multipart/form-data; boundary={boundary}",
            "Origin": self.base_url,
            "Referer": f"{self.base_url}/chat/",
        }
        
        try:
            r = self.session.post(
                self.ajax_url,
                headers=headers,
                data=data,
                timeout=60
            )
            
            if r.status_code == 200:
                content_encoding = r.headers.get('content-encoding', '')
                decoded = self.decompress_response(r.content, content_encoding) if content_encoding else r.text
                
                try:
                    result = json.loads(decoded)
                    
                    if result.get("success"):
                        response_text = result.get("data", {}).get("response", "")
                        
                        if "conversation_id" in result.get("data", {}):
                            self.conversation_id = result["data"]["conversation_id"]
                        
                        return {
                            "success": True,
                            "response": response_text,
                            "conversation_id": self.conversation_id
                        }
                    else:
                        return {
                            "success": False,
                            "error": result.get("message", "Unknown error")
                        }
                        
                except json.JSONDecodeError:
                    return {
                        "success": False,
                        "error": "Invalid JSON response"
                    }
            else:
                return {
                    "success": False,
                    "error": f"HTTP {r.status_code}"
                }
                
        except Exception as e:
            return {
                "success": False,
                "error": str(e)
            }
    
    def get_random_salam(self) -> str:
        """الحصول على رسالة سلام عشوائية"""
        available_indices = [i for i in range(len(SALAM_MESSAGES)) if i != self.last_index]
        
        if not available_indices:
            self.last_index = -1
            available_indices = list(range(len(SALAM_MESSAGES)))
        
        random_index = random.choice(available_indices)
        self.last_index = random_index
        
        return SALAM_MESSAGES[random_index]
    
    def set_system_prompt(self, prompt_type: str):
        """تعيين system prompt"""
        if prompt_type in SYSTEM_PROMPTS:
            self.system_prompt = SYSTEM_PROMPTS[prompt_type]
            return True
        return False

# ==================== تهيئة العميل ====================

client = DeepSeekClient()

# ==================== نقاط النهاية ====================

@app.route('/', methods=['GET'])
def index():
    """الصفحة الرئيسية - تعرض رد عشوائي من الذكاء الاصطناعي"""
    salam_message = client.get_random_salam()
    result = client.send_message(salam_message, "deepseek-reasoner")
    
    if result and result.get('success'):
        return jsonify({
            "sent_message": salam_message,
            "response": result['response'],
            "conversation_id": result.get('conversation_id')
        })
    else:
        error_msg = result.get('error', 'فشل في الحصول على رد') if result else 'فشل الاتصال'
        return jsonify({
            "error": error_msg
        }), 500

@app.route('/salam', methods=['GET'])
def salam_get():
    """نقطة نهاية السلام - تعرض رد عشوائي من الذكاء الاصطناعي"""
    salam_message = client.get_random_salam()
    result = client.send_message(salam_message, "deepseek-reasoner")
    
    if result and result.get('success'):
        return jsonify({
            "sent_message": salam_message,
            "response": result['response'],
            "conversation_id": result.get('conversation_id')
        })
    else:
        error_msg = result.get('error', 'فشل في الحصول على رد') if result else 'فشل الاتصال'
        return jsonify({
            "error": error_msg
        }), 500

@app.route('/salam', methods=['POST'])
def salam_post():
    """POST: إرسال رسالة سلام"""
    try:
        data = request.get_json()
        
        if not data:
            return jsonify({"error": "يجب إرسال بيانات JSON"}), 400
        
        user_message = data.get('message', '').strip()
        model = data.get('model', 'deepseek-reasoner')
        system_prompt_type = data.get('system_prompt', 'default')
        
        if system_prompt_type in SYSTEM_PROMPTS:
            client.set_system_prompt(system_prompt_type)
        
        if not user_message:
            user_message = client.get_random_salam()
        
        result = client.send_message(user_message, model)
        
        if result and result.get('success'):
            return jsonify({
                "success": True,
                "sent_message": user_message,
                "response": result['response'],
                "conversation_id": result.get('conversation_id')
            })
        else:
            return jsonify({
                "success": False,
                "error": result.get('error', 'فشل في الحصول على رد') if result else 'فشل الاتصال'
            }), 500
            
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route('/chat', methods=['POST'])
def chat():
    """نقطة نهاية المحادثة العامة"""
    try:
        data = request.get_json()
        
        if not data:
            return jsonify({"error": "يجب إرسال بيانات JSON"}), 400
        
        message = data.get('message', '').strip()
        model = data.get('model', 'deepseek-reasoner')
        system_prompt_type = data.get('system_prompt', 'default')
        
        if system_prompt_type in SYSTEM_PROMPTS:
            client.set_system_prompt(system_prompt_type)
        
        if not message:
            return jsonify({"error": "الرسالة مطلوبة"}), 400
        
        result = client.send_message(message, model)
        
        if result and result.get('success'):
            return jsonify({
                "success": True,
                "response": result['response'],
                "conversation_id": result.get('conversation_id')
            })
        else:
            return jsonify({
                "success": False,
                "error": result.get('error', 'فشل في الحصول على رد') if result else 'فشل الاتصال'
            }), 500
            
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route('/system_prompt', methods=['GET'])
def get_system_prompt():
    """الحصول على system prompt الحالي"""
    return jsonify({
        "current_system_prompt": client.system_prompt,
        "available_prompts": list(SYSTEM_PROMPTS.keys())
    })

@app.route('/system_prompt', methods=['POST'])
def set_system_prompt():
    """تعيين system prompt جديد"""
    try:
        data = request.get_json()
        
        if not data:
            return jsonify({"error": "يجب إرسال بيانات JSON"}), 400
        
        prompt_type = data.get('prompt_type', 'default')
        
        if prompt_type in SYSTEM_PROMPTS:
            client.set_system_prompt(prompt_type)
            return jsonify({
                "success": True,
                "system_prompt": client.system_prompt,
                "prompt_type": prompt_type
            })
        else:
            return jsonify({
                "error": f"نوع system prompt غير صالح. المتاح: {list(SYSTEM_PROMPTS.keys())}"
            }), 400
            
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route('/reset', methods=['POST'])
def reset():
    """إعادة تعيين المحادثة"""
    client.conversation_id = None
    return jsonify({
        "success": True,
        "message": "تم إعادة تعيين المحادثة"
    })

@app.route('/health', methods=['GET'])
def health():
    """فحص الصحة"""
    return jsonify({
        "status": "ok",
        "nonce": client.nonce is not None,
        "conversation_id": client.conversation_id
    })

# ==================== تشغيل الخادم ====================

if __name__ == '__main__':
    print("""
     شغال ...""")
    app.run(host='0.0.0.0', port=8080, debug=True)
